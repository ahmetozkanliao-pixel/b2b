{
  "expo": {
    "name": "B2B Üretim Platformu",
    "slug": "b2b-platform",
    "owner": "myaoz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.ahmetozkanli.b2b",
      "supportsTablet": true
    },
    "android": {
      "package": "com.ahmetozkanli.b2b",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 3
    },
    "scheme": "b2b",
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "webBaseUrl": "https://b2b212.vercel.app",
      "eas": {
        "projectId": "1c51601c-90c0-4366-b085-ecfb906e9073"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
