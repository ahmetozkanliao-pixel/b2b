# Demo modu (Supabase olmadan canlı yayın için true yapın)
DEMO_MODE=true
# Middleware (Edge) için de gerekli
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (gerçek DB için doldurun)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Eski anon key veya yeni publishable key — ikisinden biri yeterli
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site (canlı URL — Vercel'de otomatik ayarlanabilir)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — kayıt doğrulama e-postaları
RESEND_API_KEY=
EMAIL_FROM=B2B Platform <onboarding@resend.dev>

# Payment (optional)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
